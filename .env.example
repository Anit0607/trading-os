# Trading OS runtime mode: paper | readonly | live
TRADING_OS_MODE=paper

# Keep all writable state on D drive
TRADING_OS_ROOT=D:\Codex_Scanner\trading_os
TRADING_OS_DB=D:\Codex_Scanner\trading_os\data\trading_os.db
TRADING_OS_HOST=127.0.0.1
TRADING_OS_PORT=8765

# Safety: live order placement must stay false until we explicitly enable it.
AUTO_EXECUTION_ENABLED=false

# Dhan credentials. Prefer setting these in D:\Codex_Scanner\trading_os\.env
# or reuse D:\Codex_Scanner\.env if already present.
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=

# Optional Dhan token manager settings.
# Keep these only on your own machine/server. Do not share them in chat.
DHAN_TOKEN_STATE=D:\Codex_Scanner\trading_os\data\dhan\token_state.json

# Optional fully automated fresh-token generation.
# Requires TOTP to be enabled in Dhan.
DHAN_PIN=
DHAN_TOTP_SECRET=

# Optional API-key consent flow, if enabled for your Dhan app.
DHAN_API_KEY=
DHAN_API_SECRET=

# Optional alert delivery.
# App/local notification history is enabled by default.
ALERTS_APP_ENABLED=true

# Telegram stays disabled until you explicitly turn it on and provide both values.
ALERTS_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional zero-cost cloud mirror.
# Local machine: set TRADING_OS_SYNC_TO_NEON=true only after DATABASE_URL is configured.
# Vercel: set TRADING_OS_CLOUD_READONLY=true and DATABASE_URL in Project Settings.
DATABASE_URL=
TRADING_OS_SYNC_TO_NEON=false
TRADING_OS_CLOUD_READONLY=false
TRADING_OS_WORKER_ID=local-d-drive-worker
TRADING_OS_CLOUD_STALE_AFTER_MINUTES=180
